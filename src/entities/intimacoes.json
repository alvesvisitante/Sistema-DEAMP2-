        "bsonType": "string", 
        "description": "ID do agente responsável"
      },
      "intimado_nome": {
        "bsonType": "string",
        "minLength": 3,
        "description": "Nome completo do intimado"
      },
      "intimado_cpf": {
        "bsonType": "string",
        "pattern": "^[0-9]{11}$",
        "description": "CPF do intimado (apenas números)"
      },
      "intimado_endereco": {
        "bsonType": "string",
        "description": "Endereço completo do intimado"
      },
      "intimado_telefone": {
        "bsonType": "string",
        "description": "Telefone do intimado"
      },
      "motivo": {
        "bsonType": "string",
        "enum": ["depoimento", "audiencia", "reconhecimento", "outros"],
        "description": "Motivo da intimação"
      },
      "descricao_motivo": {
        "bsonType": "string",
        "description": "Descrição detalhada do motivo"
      },
      "data_intimacao": {
        "bsonType": "string",
        "title": "datetime",
        "description": "Data/hora da intimação"
      },
      "data_comparecimento": {
        "bsonType": "string",
        "title": "datetime", 
        "description": "Data/hora para comparecimento"
      },
      "local_comparecimento": {
        "bsonType": "string",
        "description": "Local onde deve comparecer"
      },
      "status": {
        "bsonType": "string",
