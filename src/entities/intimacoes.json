      },
      "data_entrega": {
        "bsonType": "string",
        "title": "datetime",
        "description": "Data/hora da entrega"
      },
      "responsavel_recebimento": {
        "bsonType": "string",
        "description": "Nome de quem recebeu a intimação"
      },
      "created_at": {
        "bsonType": "string",
        "title": "datetime",
        "description": "Data de criação do registro"
      },
      "updated_at": {
        "bsonType": "string", 
        "title": "datetime",
        "description": "Data da última atualização"
